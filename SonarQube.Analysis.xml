<?xml version="1.0" encoding="utf-8"?>
<SonarQubeAnalysisProperties
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
  xmlns="http://www.sonarsource.com/msbuild/integration/2015/1"
>
  <Property Name="sonar.host.url">https://sonarcloud.io</Property>
  <Property Name="sonar.scanner.scanAll">true</Property>
  <Property Name="sonar.sourceEncoding">UTF-8</Property>
  <Property Name="sonar.exclusions">
        src/Services/**/**/Infrastructure/Migrations/**,**/node_modules/**,**/.next/**,**/.turbo/**,**/dist/**,**/out/**,src/Clients/packages/ui/src/components/**,**/mockServiceWorker.js,.github/workflows/*.lock.yml,src/Clients/packages/ui/src/styles/globals.css
    </Property>
  <Property Name="sonar.cpd.exclusions">
        **/Program.cs,src/Aspire/Edvantix.AppHost/Container/**,**/Agents/**,**/*Extensions.cs
    </Property>
  <Property Name="sonar.coverage.exclusions">
        src/Services/**/**/Infrastructure/**,**/*Extensions.cs,**/Program.cs,src/BuildingBlocks/**,src/Integrations/**,src/Aspire/**,**/Agents/**,**/Orchestration/EndpointMapping.cs,**/Orchestration/WorkflowRegistration.cs,**/Saga/Activities/**,src/Clients/**
    </Property>
  <Property Name="sonar.cs.vstest.reportsPaths">
        test-results/*.trx
    </Property>
  <Property Name="sonar.cs.vscoveragexml.reportsPaths">
        test-results/*.xml
    </Property>
  <Property Name="sonar.sarifReportPaths">
        results.sarif
    </Property>
  <Property Name="sonar.architecture.configpath">
        ./.sonarlint/architecture.json
    </Property>
</SonarQubeAnalysisProperties>
