{
  "name": "@edvantix/clients",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "e2e": "turbo test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.1",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.7.3",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=25.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@scarf/scarf",
      "core-js-pure",
      "esbuild",
      "msw",
      "protobufjs",
      "sharp"
    ]
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "input-otp": "^1.4.2",
    "vaul": "^1.1.2"
  }
}
