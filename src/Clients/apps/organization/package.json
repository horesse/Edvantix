{
  "name": "@edvantix/organizationfront",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "bddgen": "npx bddgen",
    "bddgen:watch": "npx bddgen --watch",
    "bddgen:export": "npx bddgen export",
    "test:e2e": "npx bddgen && npx playwright test",
    "test:e2e:headed": "npx bddgen && npx playwright test --headed",
    "test:e2e:ui": "npx bddgen && npx playwright test --ui",
    "test:e2e:ci": "npx bddgen && npx playwright test --workers=4",
    "playwright:install": "playwright install --with-deps chromium",
    "playwright:install:all": "playwright install --with-deps",
    "allure:generate": "allure generate --output allure-report allure-results",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "1.6.1",
    "better-auth": "^1.5.4",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "ts-pattern": "^5.9.0",
    "usehooks-ts": "3.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@cucumber/cucumber": "^12.7.0",
    "@cucumber/pretty-formatter": "^3.2.0",
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@workspace/api-client": "workspace:*",
    "@workspace/api-hooks": "workspace:*",
    "@workspace/types": "workspace:*",
    "@workspace/ui": "workspace:*",
    "@workspace/utils": "workspace:*",
    "@workspace/validations": "workspace:*",
    "allure": "^3.3.1",
    "allure-playwright": "^3.6.0",
    "allure-vitest": "^3.6.0",
    "cucumber-html-reporter": "^7.2.0",
    "eslint": "^10.0.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "happy-dom": "^20.8.3",
    "multiple-cucumber-html-reporter": "^3.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
