{
  "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
  "tasks": [
    {
      "name": "format",
      "command": "dnx",
      "args": ["csharpier", "format", "."]
    },
    {
      "name": "style",
      "command": "dnx",
      "args": ["csharpier", "check", "."]
    },
    {
      "name": "analyzers",
      "command": "dotnet",
      "args": ["format", "analyzers", ".", "--verify-no-changes"]
    }
  ]
}
