{
  "name": "@edvantix/keycloakify",
  "version": "1.0.0",
  "description": "Keycloakify-based authentication UI theme for Edvantix's identity and access management",
  "author": "horesse <deepheath322@gmail.com> (https://github.com/edvantix)",
  "licenses": [
    {
      "type": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edvantix/Edvantix.git",
    "directory": "src/Aspire/Edvantix.AppHost/Container/keycloak/keycloakify"
  },
  "bugs": {
    "url": "https://github.com/edvantix/Edvantix/issues"
  },
  "homepage": "https://github.com/edvantix/Edvantix#readme",
  "type": "module",
  "scripts": {
    "prepare": "allow-scripts",
    "postinstall": "keycloakify sync-extensions",
    "dev": "vite",
    "build": "tsc && vite build",
    "build-keycloak-theme": "bun run build && keycloakify build",
    "storybook": "storybook dev -p 6006",
    "format": "prettier --write .",
    "check": "eslint . && prettier --check .",
    "lint": "eslint --fix .",
    "ci": "eslint . && prettier --check ."
  },
  "lavamoat": {
    "allowScripts": {
      "keycloakify": true,
      "$root$": false,
      "vite>esbuild": false
    }
  },
  "dependencies": {
    "keycloakify": "^11.15.1",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^0.577.0",
    "clsx": "^2.1.1",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "@keycloakify/email-native": "~260007.0.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lavamoat/allow-scripts": "^3.4.3",
    "@types/node": "^25.5.0",
    "@storybook/react-vite": "^10.2.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "storybook": "^10.2.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0"
  },
  "engines": {
    "node": "^18.0.0 || >=20.0.0"
  }
}
