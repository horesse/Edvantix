<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <SuppressCheckGrpcNetClientFactoryVersion>true</SuppressCheckGrpcNetClientFactoryVersion>
  </PropertyGroup>
  <ItemGroup>
    <!-- Allow unit test project to access internal types (e.g. EventMapper) -->
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
    <InternalsVisibleTo Include="$(AssemblyName).UnitTests" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Grpc.Tools" PrivateAssets="all" />
    <PackageReference Include="Grpc.AspNetCore.Server.ClientFactory" />
    <PackageReference Include="MassTransit.EntityFrameworkCore" />
    <PackageReference Include="Mediator.SourceGenerator" PrivateAssets="all" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Tools" />
    <PackageReference Include="Microsoft.Extensions.Http.Resilience" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\Aspire\Edvantix.ServiceDefaults\Edvantix.ServiceDefaults.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Protobuf Include="Grpc\Protos\persona\v1\profile.proto" GrpcServices="Client" />
    <!-- permissions.proto types (Server base class + messages) are generated by Edvantix.Chassis to avoid
         duplicate type conflicts. This project uses PermissionsGrpcService.PermissionsGrpcServiceBase
         and message types from the Chassis-generated assembly. -->
    <!-- groups.proto: client stub for the Organizations Groups gRPC service. Source lives in Organizations;
         referenced via Link= so there is no copy — same pattern as profile.proto in Blog/Scheduling. -->
    <Protobuf
      Include="..\..\Organizations\Edvantix.Organizations\Grpc\Protos\organizations\v1\groups.proto"
      Link="Grpc\Protos\organizations\v1\groups.proto"
      GrpcServices="Client"
    />
  </ItemGroup>
</Project>
